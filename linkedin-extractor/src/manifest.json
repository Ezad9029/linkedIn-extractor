{
  "manifest_version": 3,
  "name": "LinkedIn Profile Extractor",
  "version": "1.0.1",
  "description": "Extract LinkedIn profile data and export to Excel/CSV",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://linkedin.com/*",
    "https://www.linkedin.com/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "LinkedIn Profile Extractor"
  }
}